{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "node"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src/",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "scripts"
  ]
}
